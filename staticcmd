-- DOORS DESPAWN (أ„آگأ،آ»â€¢i phأƒآ²ng tأ،آ»آ± biأ،آ؛آ؟n mأ،آ؛آ¥t)
local latestRoom = ReplicatedStorage.GameData.LatestRoom
local lastRoom = latestRoom.Value

latestRoom:GetPropertyChangedSignal("Value"):Connect(function()
    if destroyed then return end

    if latestRoom.Value ~= lastRoom then
        passedDoors += 1
        lastRoom = latestRoom.Value

        if passedDoors >= 3 then
