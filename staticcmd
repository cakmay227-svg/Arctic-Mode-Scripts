-- RANDOM POSITION
local function getSpawnPosition()
    local half = HITBOX_SIZE / 2

    while true do
        local randomPos =
            hrp.Position +
            Vector3.new(
                math.random(-half,half),
                2,
                math.random(-half,half)
            )

        local distance =
            (randomPos - hrp.Position).Magnitude

        if distance >= MIN_DISTANCE then
            return randomPos
        end
    end
end

local spawnPosition = getSpawnPosition()

