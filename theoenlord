local function GitAud(soundlink, filename)
    local url = soundlink
    local FileName = filename
    if not isfile(FileName..".mp3") then
        writefile(FileName..".mp3", game:HttpGet(url))
    end
    return (getcustomasset or getsynasset)(FileName..".mp3")
end


local currentLoopSound = nil
local isEntityAlive = false


local function PlayEntityTheme()
    isEntityAlive = true
    
    local startAsset = GitAud("https://github.com/vuivuiviu2/Frost-Mode/raw/refs/heads/main/Leak%20Music%20start.mp3", "frost_start")
    local loopAsset = GitAud("https://github.com/vuivuiviu2/Frost-Mode/raw/refs/heads/main/Loop.mp3", "frost_loop")
    
    local startSound = Instance.new("Sound")
    startSound.Name = "Frost_Start"
    startSound.SoundId = startAsset
    startSound.Volume = 2
    startSound.Looped = false
    startSound.Parent = workspace
    
    startSound:Play()
    
    startSound.Ended:Wait() 
    startSound:Destroy()
    
    if isEntityAlive and not currentLoopSound then
        local loopSound = Instance.new("Sound")
        loopSound.Name = "Frost_Loop"
        loopSound.SoundId = loopAsset
        loopSound.Volume = 2
        loopSound.Looped = true
        loopSound.Parent = workspace
        
        loopSound:Play()
        currentLoopSound = loopSound
    end
end


local function StopEntityTheme()
    isEntityAlive = false
    
    if currentLoopSound then
        currentLoopSound:Stop()
        currentLoopSound:Destroy()
        currentLoopSound = nil
    end
    
    local endAsset = GitAud("https://github.com/vuivuiviu2/Frost-Mode/raw/refs/heads/main/end.mp3", "frost_end")
    
    local endSound = Instance.new("Sound")
    endSound.Name = "Frost_End"
    endSound.SoundId = endAsset
    endSound.Volume = 2
    endSound.Looped = false
    endSound.Parent = workspace
    
    endSound:Play()
    
    task.spawn(function()
        endSound.Ended:Wait()
        endSound:Destroy()
    end)
end


