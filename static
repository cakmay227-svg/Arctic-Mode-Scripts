        return
    end
    getgenv()._STATIC_ALREADY_EXECUTED = true

    local success, achievementGiver = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/Voor-Pr00/Achivements/refs/heads/main/Voorpr0"))()
